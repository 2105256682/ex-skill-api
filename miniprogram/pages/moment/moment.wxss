/* 页面容器 */
.container {
  height: 100vh;
  background: #f5f5f7;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.nav-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #fff;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.back-icon {
  font-size: 44rpx;
  color: #000;
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #000;
  margin-left: 16rpx;
}

/* 内容区域 */
.page-content {
  flex: 1;
  height: 0;
  background: #f5f5f7;
}

/* 副标题 */
.subtitle {
  padding: 24rpx 32rpx 16rpx;
}

.subtitle text {
  font-size: 26rpx;
  color: #8e8e93;
}

/* 心情选择 */
.mood-section {
  padding: 0 24rpx 24rpx;
}

.mood-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #c7c7cc;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.mood-scroll {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  overflow-x: auto;
  padding: 8rpx 4rpx;
  white-space: nowrap;
}

.mood-scroll::-webkit-scrollbar {
  display: none;
}

.mood-card {
  flex-shrink: 0;
  height: 100rpx;
  background: #fff;
  border-radius: 50rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 24rpx 0 16rpx;
  gap: 16rpx;
  transition: all 0.25s ease;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.mood-card.active {
  background: #1c1c1e;
  transform: scale(1.05);
}

.mood-card:active {
  transform: scale(0.95);
}

.emoji-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mood-emoji {
  font-size: 40rpx;
}

.mood-info {
  display: flex;
  flex-direction: column;
}

.mood-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.mood-card.active .emoji-circle {
  background: #fff !important;
}

.mood-card.active .mood-name {
  color: #fff;
}

/* 备注输入 */
.note-section {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.note-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #c7c7cc;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.note-input {
  width: 100%;
  border: none;
  outline: none;
  font-size: 30rpx;
  color: #1c1c1e;
  min-height: 100rpx;
  line-height: 1.6;
}

.note-input::placeholder {
  color: #c7c7cc;
}

/* 发送按钮 */
.send-btn {
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  background: #000;
  color: #fff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.send-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* 我的心情卡片 */
.my-mood-card {
  margin: 0 32rpx 32rpx;
  background: #1c1c1e;
  border-radius: 40rpx;
  padding: 36rpx;
  color: #fff;
}

.my-mood-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.my-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.my-mood-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.my-mood-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.my-mood-time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}

.my-mood-body {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 20rpx 28rpx;
}

.my-mood-emoji {
  font-size: 48rpx;
}

.my-mood-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  flex: 1;
}

/* TA的动态 */
.feed-section {
  padding: 0 32rpx 32rpx;
}

.feed-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.feed-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #c7c7cc;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.feed-tabs {
  display: flex;
  gap: 16rpx;
}

.feed-tab {
  background: #fff;
  border: none;
  border-radius: 28rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #8e8e93;
}

.feed-tab.active {
  background: #1c1c1e;
  color: #fff;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.message-item {
  display: flex;
  gap: 20rpx;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.message-content {
  flex: 1;
}

.message-bubble {
  background: #fff;
  border-radius: 36rpx;
  border-bottom-left-radius: 8rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.message-text {
  display: block;
  font-size: 28rpx;
  color: #1c1c1e;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.message-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.message-mood-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.message-time {
  font-size: 22rpx;
  color: #c7c7cc;
}

.message-reply-btn {
  margin-top: 16rpx;
  padding: 12rpx 24rpx;
  background: transparent;
  border: 2rpx solid #e5e5ea;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #8e8e93;
  display: inline-block;
}

.message-reply-btn:active {
  background: #1c1c1e;
  color: #fff;
  border-color: #1c1c1e;
}

/* 底部占位 */
.bottom-placeholder {
  height: 200rpx;
}