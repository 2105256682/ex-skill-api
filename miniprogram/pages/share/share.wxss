/* 页面容器 */
.container {
  min-height: 100vh;
  background: #fff;
  box-sizing: border-box;
}

/* 顶部导航 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
}

.back-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 22px;
  color: #333;
  font-weight: bold;
}

.header-title {
  font-size: 18px;
  font-weight: 700;
  color: #000;
}

.placeholder {
  width: 36px;
}

/* 页面内容 */
.page-content {
  padding: 0 20px 40px;
  height: calc(100vh - 70px);
}

/* 分享卡片 */
.share-card {
  background: #000;
  border-radius: 24px;
  padding: 28px 24px;
  margin-bottom: 32px;
  position: relative;
  overflow: hidden;
}

.card-content {
  position: relative;
  z-index: 1;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.avatar-box {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 24px;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.user-name {
  font-size: 16px;
  font-weight: 700;
  color: #fff;
}

.user-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.4);
}

.share-desc {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  line-height: 1.6;
  margin-bottom: 24px;
}

/* 二维码 */
.qr-box {
  width: 160px;
  height: 160px;
  background: #fff;
  border-radius: 16px;
  padding: 12px;
  margin: 0 auto;
}

.qr-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: repeating-linear-gradient(
    0deg,
    #000 0px, #000 8px,
    #fff 8px, #fff 16px
  ),
  repeating-linear-gradient(
    90deg,
    #000 0px, #000 8px,
    #fff 8px, #fff 16px
  );
  border-radius: 8px;
}

.qr-icon {
  font-size: 32px;
  background: #fff;
  padding: 8px;
  border-radius: 4px;
}

.qr-hint {
  display: block;
  text-align: center;
  font-size: 12px;
  color: rgba(255,255,255,0.3);
  margin-top: 16px;
}

/* 区块标题 */
.section {
  margin-bottom: 28px;
}

.section-title {
  display: block;
  font-size: 12px;
  font-weight: 700;
  color: #000;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 16px;
}

/* 平台按钮 */
.platform-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.platform-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 12px 8px;
  border-radius: 16px;
  background: #fafafa;
}

.platform-icon {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.platform-name {
  font-size: 12px;
  color: #666;
  font-weight: 500;
}

/* 复制链接 */
.copy-box {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #fafafa;
  border-radius: 16px;
  padding: 14px 16px;
  border: 1px solid #f0f0f0;
}

.copy-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.copy-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.copy-main {
  font-size: 14px;
  font-weight: 600;
  color: #000;
}

.copy-url {
  font-size: 12px;
  color: #999;
}

.copy-arrow {
  font-size: 20px;
  color: #ccc;
}

/* 操作列表 */
.action-list {
  background: #fafafa;
  border-radius: 20px;
  padding: 8px 16px;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 0;
  border-bottom: 1px solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.action-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.action-main {
  font-size: 14px;
  font-weight: 600;
  color: #000;
}

.action-sub {
  font-size: 12px;
  color: #999;
}

.action-arrow {
  font-size: 20px;
  color: #ccc;
}

/* Toast */
.toast {
  position: fixed;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: #000;
  color: #fff;
  padding: 12px 24px;
  border-radius: 100px;
  font-size: 14px;
  font-weight: 500;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
  z-index: 100;
  white-space: nowrap;
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
