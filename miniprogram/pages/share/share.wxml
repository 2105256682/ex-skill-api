<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="header-title">分享</text>
    <view class="placeholder"></view>
  </view>

  <scroll-view class="page-content" scroll-y>
    <!-- 分享卡片 -->
    <view class="share-card">
      <view class="card-content">
        <view class="user-info">
          <view class="avatar-box">
            <text class="avatar-emoji">🎭</text>
          </view>
          <view class="user-detail">
            <text class="user-name">{{userName || 'Vexill'}}</text>
            <text class="user-sub">分享我的主页</text>
          </view>
        </view>
        
        <text class="share-desc">来看看我的主页，一起交流互动吧！</text>
        
        <!-- 二维码 -->
        <view class="qr-box">
          <view class="qr-inner">
            <text class="qr-icon">⬜</text>
          </view>
        </view>
        
        <text class="qr-hint">扫码访问我的主页</text>
      </view>
    </view>

    <!-- 分享至 -->
    <view class="section">
      <text class="section-title">分享至</text>
      <view class="platform-grid">
        <view class="platform-btn" bindtap="shareTo" data-platform="微信">
          <view class="platform-icon">
            <text>💬</text>
          </view>
          <text class="platform-name">微信</text>
        </view>
        
        <view class="platform-btn" bindtap="shareTo" data-platform="朋友圈">
          <view class="platform-icon">
            <text>👥</text>
          </view>
          <text class="platform-name">朋友圈</text>
        </view>
        
        <view class="platform-btn" bindtap="shareTo" data-platform="QQ">
          <view class="platform-icon">
            <text>🐧</text>
          </view>
          <text class="platform-name">QQ</text>
        </view>
        
        <view class="platform-btn" bindtap="shareTo" data-platform="微博">
          <view class="platform-icon">
            <text>📡</text>
          </view>
          <text class="platform-name">微博</text>
        </view>
      </view>
    </view>

    <!-- 复制链接 -->
    <view class="section">
      <text class="section-title">链接</text>
      <view class="copy-box" bindtap="copyLink">
        <view class="copy-icon">
          <text>🔗</text>
        </view>
        <view class="copy-text">
          <text class="copy-main">复制链接</text>
          <text class="copy-url">vexill.app/u/{{userName || 'Vexill'}}</text>
        </view>
        <text class="copy-arrow">›</text>
      </view>
    </view>

    <!-- 更多操作 -->
    <view class="section">
      <text class="section-title">更多</text>
      <view class="action-list">
        <view class="action-item" bindtap="saveImage">
          <view class="action-icon">
            <text>🖼️</text>
          </view>
          <view class="action-info">
            <text class="action-main">保存图片</text>
            <text class="action-sub">将分享卡片保存到相册</text>
          </view>
          <text class="action-arrow">›</text>
        </view>
        
        <view class="action-item" bindtap="report">
          <view class="action-icon">
            <text>⚠️</text>
          </view>
          <view class="action-info">
            <text class="action-main">举报</text>
            <text class="action-sub">反馈违规内容</text>
          </view>
          <text class="action-arrow">›</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Toast -->
  <view class="toast {{showToast ? 'show' : ''}}">
    <text>{{toastText}}</text>
  </view>
</view>
