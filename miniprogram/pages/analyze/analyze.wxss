.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

/* 顶部导航栏 */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  z-index: 100;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}

.top-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.placeholder {
  width: 64rpx;
}

/* 分析进度中 */
.analyze-section {
  padding: 200rpx 60rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.persona-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 80rpx;
}

/* 头像进度指示器 */
.avatar-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.avatar-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.avatar-circle.active {
  background: #fff;
  transform: scale(1.1);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.avatar-emoji {
  font-size: 40rpx;
  opacity: 0.5;
}

.avatar-circle.active .avatar-emoji {
  opacity: 1;
}

.connecting-line {
  width: 40rpx;
  height: 4rpx;
  background: rgba(255,255,255,0.3);
  margin: 0 8rpx;
  transition: background 0.3s;
}

.connecting-line.active {
  background: rgba(255,255,255,0.8);
}

/* 当前步骤 */
.current-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.step-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  animation: pulse 2s infinite;
}

.step-desc {
  font-size: 30rpx;
  color: rgba(255,255,255,0.9);
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

/* 进度条 */
.progress-wrap {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-bg {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 28rpx;
  color: #fff;
  width: 80rpx;
  text-align: right;
}

.tip-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 40rpx;
}

/* 结果区域 */
.result-section {
  padding: 200rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: bounce 1s ease;
}

@keyframes bounce {
  0% { transform: scale(0); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 60rpx;
}

/* 人格卡片 */
.persona-card {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
  margin-bottom: 60rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.card-emoji {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.card-info {
  display: flex;
  flex-direction: column;
}

.card-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.card-style {
  font-size: 26rpx;
  color: #666;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tag {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 20rpx;
}

.card-features {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feature-title {
  font-size: 26rpx;
  color: #999;
}

.feature-item {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 开始聊天按钮 */
.start-btn {
  width: 100%;
  height: 100rpx;
  background: #fff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.start-btn:active {
  transform: scale(0.98);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
}

.btn-arrow {
  font-size: 40rpx;
  color: #667eea;
  margin-left: 8rpx;
}
