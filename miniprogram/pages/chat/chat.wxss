page {
  background: #f5f7fa;
  height: 100%;
}

.chat-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f5f7fa 0%, #e8ecf1 100%);
}

/* ── 顶部导航栏 ── */
.header {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 12rpx);
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  z-index: 100;
  flex-shrink: 0;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.05);
}
.back-btn:active {
  background: rgba(0,0,0,0.1);
}
.back-arrow {
  font-size: 48rpx;
  color: #333;
  font-weight: 300;
}

.user-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-left: 16rpx;
}

.avatar-wrapper {
  position: relative;
}
.avatar-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #1a1a1a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 2rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}
.online-indicator {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 20rpx;
  height: 20rpx;
  background: #4cd964;
  border-radius: 50%;
  border: 3rpx solid #fff;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.2); }
}

.user-details {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.user-status {
  font-size: 24rpx;
  color: #4cd964;
  display: flex;
  align-items: center;
}
.user-status::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  background: #4cd964;
  border-radius: 50%;
  margin-right: 8rpx;
}

.menu-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 50%;
}
.menu-btn:active {
  background: rgba(0,0,0,0.1);
}
.menu-line {
  width: 40rpx;
  height: 4rpx;
  background: #333;
  border-radius: 2rpx;
}

/* ── 聊天区域 ── */
.chat-area {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.chat-area::-webkit-scrollbar {
  display: none;
}

.time-tag {
  text-align: center;
  font-size: 22rpx;
  color: #8e8e93;
  margin: 8rpx 0 24rpx;
}

/* ── 消息气泡 ── */
.message {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  max-width: 85%;
  animation: messageAppear 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes messageAppear {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message.sent {
  align-self: flex-end;
  flex-direction: row-reverse;
}

.message.received {
  align-self: flex-start;
}

.bubble-received {
  background: #ffffff;
  color: #1a1a1a;
  padding: 20rpx 28rpx;
  border-radius: 32rpx;
  border-bottom-left-radius: 8rpx;
  font-size: 30rpx;
  line-height: 1.5;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  position: relative;
}

.bubble-sent {
  background: #1a1a1a;
  color: #ffffff;
  padding: 20rpx 28rpx;
  border-radius: 32rpx;
  border-bottom-right-radius: 8rpx;
  font-size: 30rpx;
  line-height: 1.5;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.msg-text {
  display: block;
  word-wrap: break-word;
}

.message-status {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 4rpx;
  margin-top: 8rpx;
}
.time {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}
.read-icon {
  font-size: 20rpx;
  color: #4cd964;
}

.msg-time {
  font-size: 22rpx;
  color: #8e8e93;
  text-align: left;
  margin-left: 100rpx;
  margin-top: -8rpx;
  margin-bottom: 12rpx;
}

/* ── 打字指示器 ── */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 28rpx;
  background: #ffffff;
  border-radius: 32rpx;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  align-self: flex-start;
  margin-bottom: 16rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background: #8e8e93;
  border-radius: 50%;
  animation: typingBounce 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-12rpx); }
}

/* ── 输入区域 ── */
.input-area {
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 12rpx 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 12rpx);
  border-top: 1rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  z-index: 100;
  flex-shrink: 0;
}

.input-wrapper {
  flex: 1;
  background: #f2f2f7;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  gap: 12rpx;
}

.attach-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  flex-shrink: 0;
}
.attach-btn:active {
  background: rgba(0,0,0,0.1);
}
.attach-icon {
  font-size: 44rpx;
}

.message-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 30rpx;
  color: #1a1a1a;
  outline: none;
  max-height: 200rpx;
  line-height: 1.4;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e5e5ea;
  flex-shrink: 0;
  opacity: 0.5;
  pointer-events: none;
  transition: all 0.2s;
}
.send-btn.active {
  opacity: 1;
  pointer-events: all;
  background: #1a1a1a;
}
.send-btn.active .send-icon {
  color: #fff;
}
.send-btn:active {
  transform: scale(0.9);
}
.send-icon {
  font-size: 36rpx;
  color: #8e8e93;
  font-weight: bold;
}

/* ── 技能卡片 ── */
.skill-card {
  min-width: 280rpx;
}
.weather-card {
  padding: 8rpx 0;
}
.weather-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.weather-icon {
  font-size: 64rpx;
}
.weather-info {
  display: flex;
  flex-direction: column;
}
.weather-temp {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.weather-text {
  font-size: 26rpx;
  color: #8e8e93;
}
