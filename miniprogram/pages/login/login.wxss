page {
  background: #ffffff;
  height: 100%;
}

.container {
  min-height: 100vh;
  padding: 280rpx 80rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 欢迎语 */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.welcome-cn {
  font-size: 56rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 12rpx;
}

.welcome-en {
  font-size: 28rpx;
  color: #999;
  letter-spacing: 2rpx;
}

/* 微信登录区域 */
.wx-login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-login-btn {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: none;
  padding: 0;
}

.wx-login-btn::after {
  border: none;
}

.wx-login-btn.loading {
  opacity: 0.6;
}

.wx-icon {
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #07c160;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.wx-login-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.login-hint {
  font-size: 24rpx;
  color: #999;
}

/* 分隔线 */
.divider {
  width: 100%;
  display: flex;
  align-items: center;
  margin: 60rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e5e5e5;
}

.divider-text {
  font-size: 24rpx;
  color: #999;
  margin: 0 32rpx;
}

/* 跳过按钮 */
.skip-btn {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.skip-btn:active {
  background: #eee;
}

.skip-text {
  font-size: 28rpx;
  color: #666;
}

/* 注册提示 */
.register-tip {
  position: fixed;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}

.tip-text {
  font-size: 22rpx;
  color: #999;
}

.tip-link {
  font-size: 22rpx;
  color: #576b95;
}
