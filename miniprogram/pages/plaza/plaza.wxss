page {
  background: #f5f5f7;
  height: 100%;
}

.container {
  min-height: 100vh;
  padding: 180rpx 32rpx 160rpx;
  box-sizing: border-box;
}

/* 顶部导航 */
.top-nav {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.nav-icon {
  width: 72rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.nav-icon .icon {
  font-size: 36rpx;
}

.badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff4d4f;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

/* 置顶公告卡片 */
.notice-card {
  background: #1a1a1a;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.notice-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.notice-subtitle {
  font-size: 26rpx;
  color: #999;
}

.notice-tag {
  background: #333;
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 标签栏 */
.tag-list {
  display: flex;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.tag {
  padding: 16rpx 40rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.tag.active {
  background: #1a1a1a;
  color: #fff;
}

/* Check-in 签到 */
.checkin-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.checkin-title {
  display: flex;
  flex-direction: column;
}

.title-en {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.checkin-btn {
  background: #1a1a1a;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkin-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.checkin-arrow {
  font-size: 28rpx;
  color: #fff;
}

.checkin-grid {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
}

.reward-item {
  min-width: 100rpx;
  height: 100rpx;
  background: #f5f5f7;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reward-item.active {
  background: #1a1a1a;
}

.reward-num {
  font-size: 32rpx;
  font-weight: 600;
  color: #666;
}

.reward-item.active .reward-num {
  color: #fff;
}

/* Redeem 兑换码 */
.redeem-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.redeem-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.redeem-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
  display: block;
}

.redeem-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 48rpx;
  padding: 8rpx 8rpx 8rpx 32rpx;
}

.redeem-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  height: 80rpx;
}

.placeholder {
  color: #999;
  text-align: center;
}

.redeem-btn {
  width: 80rpx;
  height: 80rpx;
  background: #1a1a1a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.redeem-arrow {
  font-size: 36rpx;
  color: #fff;
}
