page {
  background: #ffffff;
  height: 100%;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 80rpx 80rpx;
  box-sizing: border-box;
}

.header-section {
  width: 100%;
  text-align: center;
  margin-bottom: 80rpx;
}
.title {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 20rpx;
}
.subtitle {
  display: block;
  font-size: 32rpx;
  color: #666;
}

.form-section {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.input-group {
  width: 100%;
  margin-bottom: 24rpx;
}
.input-wrapper {
  position: relative;
  width: 100%;
}
.input-field {
  width: 100%;
  border: none;
  border-bottom: 2rpx solid #000;
  padding: 68rpx 0 12rpx;
  font-size: 34rpx;
  background: transparent;
  color: #000;
  box-sizing: border-box;
}
.float-label {
  position: absolute;
  left: 0;
  top: 4rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #999;
  pointer-events: none;
}
.pwd-toggle {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  padding: 10rpx;
}
.eye-text {
  font-size: 26rpx;
  color: #999;
}

.register-btn {
  width: 100%;
  background: #000;
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 40rpx;
  transition: opacity 0.2s;
}
.register-btn.loading { opacity: 0.6; }

.go-login {
  text-align: center;
}
.go-login-text {
  font-size: 28rpx;
  color: #666;
}

.error-toast {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 18rpx 48rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  white-space: nowrap;
}
.error-toast.show { opacity: 1; }
