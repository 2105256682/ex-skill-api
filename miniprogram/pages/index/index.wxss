page {
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100%;
  position: relative;
}

/* ========== 第一页 ========== */
.page1 {
  position: absolute;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background-color: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  z-index: 3;
  transition:
    transform 1.4s cubic-bezier(0.32, 0.72, 0, 1),
    opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.page1.leaving {
  transform: translateY(-30vh);
  opacity: 0;
}

.title {
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 1s ease, transform 1s ease;
  font-size: 28px;
  font-weight: bold;
  color: #1a1a1a;
}
.title.active {
  opacity: 1;
  transform: scale(1);
}

/* ========== 第二页 ========== */
.page2 {
  position: absolute;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 2;
  transform: translateY(100vh);
  opacity: 0;
  transition:
    transform 1.4s cubic-bezier(0.32, 0.72, 0, 1),
    opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}
.page2.entering {
  transform: translateY(0);
  opacity: 1;
}

/* 第二页离开 */
.page2.leaving {
  transform: translateY(-30vh);
  opacity: 0;
}

.bg-v {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 20vw;
  font-weight: 900;
  color: rgba(0, 0, 0, 0.07);
  opacity: 0;
  transition: opacity 1s ease;
  z-index: 0;
}
.bg-v.show { opacity: 1; }

.exill-wrap {
  display: flex;
  justify-content: center;
  gap: 2px;
  position: relative;
  z-index: 1;
}

.char {
  font-size: 12vw;
  font-weight: 700;
  color: #1a1a1a;
  opacity: 0;
  transform: scale(0.3);
}
.char.animating {
  animation: jellyPop 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55) forwards;
}

@keyframes jellyPop {
  0%   { opacity: 0; transform: scale(0.3); }
  60%  { transform: scale(1.15); }
  80%  { transform: scale(0.95); }
  100% { opacity: 1; transform: scale(1); }
}

/* 底部中文文字 - 微软雅黑 */
.footer-text {
  position: absolute;
  bottom: 8vh;
  left: 0; right: 0;
  text-align: center;
  font-size: 3.2vw;
  font-family: "Microsoft YaHei", "微软雅黑", PingFang SC, sans-serif;
  letter-spacing: 0.15em;
  color: #888888;
  opacity: 0;
  transition: opacity 1s ease 0.6s;
}
.footer-text.active { opacity: 1; }

/* ========== 第三页 ========== */
.page3 {
  position: absolute;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background-color: #faf9f8;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  z-index: 1;
  transform: translateY(100vh);
  opacity: 0;
  transition:
    transform 1.4s cubic-bezier(0.32, 0.72, 0, 1),
    opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}
.page3.entering {
  transform: translateY(0);
  opacity: 1;
}

/* 主光晕球 */
.orb-main {
  position: absolute;
  top: 14vh;
  left: 50%;
  transform: translateX(-50%) scale(0.6);
  width: 72vw;
  height: 72vw;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #ff70a6 0%, rgba(255, 112, 166, 0.4) 30%, transparent 60%),
              radial-gradient(circle at 65% 60%, #ffb88c 0%, rgba(255, 184, 140, 0.4) 30%, transparent 60%);
  filter: blur(22px);
  opacity: 0;
  transition: opacity 1.2s ease 0.3s, transform 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s;
}
.orb-main.show {
  opacity: 0.9;
  transform: translateX(-50%) scale(1);
}

/* 装饰小圆点 */
.dot {
  position: absolute;
  border-radius: 50%;
}
.dot-pink-sm {
  width: 10vw; height: 10vw;
  background: #FFD6DC;
  top: 8%; left: 15%;
  opacity: 0.9;
}
.dot-mint {
  width: 9vw; height: 9vw;
  background: #A8F0C8;
  top: 40%; right: 10%;
  opacity: 0.9;
}
.dot-peach {
  width: 13vw; height: 13vw;
  background: #FFBCA2;
  top: 50%; left: 8%;
  opacity: 0.9;
}
.dot-hotpink {
  width: 12vw; height: 12vw;
  background: #FF4D94;
  top: 65%; right: 15%;
  opacity: 0.9;
}

/* 第三页底部内容 */
.p3-bottom {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 8vh;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.9s ease 0.6s, transform 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) 0.6s;
}
.p3-bottom.show {
  opacity: 1;
  transform: translateY(0);
}

.p3-title {
  font-size: 11vw;
  font-weight: 900;
  color: #1a1a1a;
  letter-spacing: -1px;
  margin-bottom: 6vw;
}

/* 箭头按钮 */
.p3-btn-wrap {
  margin-bottom: 4vw;
}
.p3-btn {
  width: 44vw;
  height: 16vw;
  background: #1a1a1a;
  border-radius: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.p3-btn-arrow {
  color: #ffffff;
  font-size: 7vw;
  font-weight: 400;
}

.p3-lets {
  font-size: 3.2vw;
  font-family: "Microsoft YaHei", "微软雅黑", PingFang SC, sans-serif;
  color: #666666;
  letter-spacing: 0.1em;
  margin-bottom: 5vw;
}

/* ========== 平板适配 ========== */
@media (min-width: 768px) {
  .title      { font-size: 36px; }
  .char       { font-size: 6rem; }
  .bg-v       { font-size: 11rem; }
  .footer-text{ font-size: 0.9rem; }
  .p3-title   { font-size: 4.5rem; }
}
