/* 页面容器 */
.container {
  min-height: 100vh;
  background: #f5f5f7;
  box-sizing: border-box;
  overflow-x: hidden;
  padding-bottom: 40px;
}

/* 状态栏 */
.status-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px 0;
}

.status-time {
  font-size: 15px;
  font-weight: 600;
  color: #1c1c1e;
}

.status-icons {
  display: flex;
  gap: 5px;
  align-items: center;
}

.status-icon {
  font-size: 14px;
}

/* 顶部 */
.top-section {
  padding: 8px 24px 20px;
  position: relative;
}

.top-section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 24px;
  right: 24px;
  height: 1px;
  background: linear-gradient(90deg, transparent, #d1d1d6, transparent);
}

.back-btn {
  width: 36px;
  height: 36px;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.back-icon {
  font-size: 18px;
  color: #1c1c1e;
}

.header {
  text-align: left;
}

.header-title {
  font-size: 24px;
  font-weight: 800;
  color: #1c1c1e;
  letter-spacing: -0.3px;
  display: block;
  margin-bottom: 4px;
}

.header-sub {
  font-size: 13px;
  color: #8e8e93;
}

/* 心情选择 */
.mood-section {
  padding: 24px;
}

.mood-label {
  font-size: 12px;
  font-weight: 700;
  color: #c7c7cc;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.mood-label::before {
  content: '';
  width: 4px;
  height: 4px;
  background: #c7c7cc;
  border-radius: 50%;
}

.mood-scroll {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding: 4px 4px 16px;
  white-space: nowrap;
}

.mood-scroll::-webkit-scrollbar {
  display: none;
}

.mood-card {
  flex-shrink: 0;
  width: 80px;
  height: 100px;
  background: #fff;
  border-radius: 20px;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 2px solid transparent;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
}

.mood-card:hover {
  transform: translateY(-6px) rotate(2deg);
  box-shadow: 0 12px 30px rgba(0,0,0,0.1);
}

.mood-card.active {
  background: #1c1c1e;
  transform: scale(1.08);
  box-shadow: 0 12px 30px rgba(0,0,0,0.2);
  z-index: 2;
}

.mood-card.active .mood-card-name {
  color: #fff;
}

.emoji-container {
  width: 44px;
  height: 44px;
  position: relative;
}

.emoji-fluid {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.mood-card.active .emoji-fluid {
  animation: emojiPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes emojiPop {
  0% { transform: scale(0.5); opacity: 0; }
  70% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

.emoji-face {
  font-size: 24px;
}

.mood-card-name {
  font-size: 11px;
  font-weight: 600;
  color: #8e8e93;
  transition: color 0.3s ease;
  position: relative;
  z-index: 1;
}

/* 备注输入 */
.note-section {
  margin: 0 24px 20px;
  background: #fff;
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}

.note-section:focus-within {
  border: 2px solid #000;
  box-shadow: 0 0 0 4px rgba(0,0,0,0.06);
}

.note-label {
  font-size: 12px;
  font-weight: 700;
  color: #c7c7cc;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.note-label::before {
  content: '';
  width: 4px;
  height: 4px;
  background: #c7c7cc;
  border-radius: 50%;
}

.note-input {
  width: 100%;
  border: none;
  outline: none;
  font-size: 15px;
  color: #1c1c1e;
  min-height: 50px;
  line-height: 1.6;
}

.note-input::placeholder {
  color: #c7c7cc;
}

/* 发送按钮 */
.send-btn {
  margin: 0 24px 32px;
  padding: 16px;
  background: #000;
  color: #fff;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.send-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
}

.send-btn:active {
  transform: scale(0.96);
}

.send-text {
  font-size: 16px;
  font-weight: 600;
}

/* 我的心情卡片 */
.my-mood-card {
  background: #1c1c1e;
  border-radius: 20px;
  padding: 18px;
  margin: 0 24px 28px;
  color: #fff;
  position: relative;
  overflow: hidden;
  display: none;
}

.my-mood-card.show {
  display: block;
  animation: cardIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes cardIn {
  from { opacity: 0; transform: translateY(20px) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.my-mood-card::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -15%;
  width: 160px;
  height: 160px;
  background: rgba(255,255,255,0.03);
  border-radius: 50%;
}

.my-mood-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}

.my-avatar {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
}

.my-mood-info {
  display: flex;
  flex-direction: column;
}

.my-mood-title {
  font-size: 15px;
  font-weight: 600;
}

.my-mood-time {
  font-size: 12px;
  color: rgba(255,255,255,0.45);
}

.my-mood-body {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 10px 14px;
}

.my-mood-emoji {
  font-size: 24px;
  animation: recordEmojiBounce 2s ease-in-out infinite;
}

@keyframes recordEmojiBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.my-mood-text {
  font-size: 14px;
  line-height: 1.5;
  color: rgba(255,255,255,0.9);
}

/* TA的动态流 */
.feed-section {
  padding: 0 24px;
}

.feed-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.feed-title {
  font-size: 12px;
  font-weight: 700;
  color: #c7c7cc;
  letter-spacing: 2px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 8px;
}

.feed-title::before {
  content: '';
  width: 4px;
  height: 4px;
  background: #c7c7cc;
  border-radius: 50%;
}

.feed-tabs {
  display: flex;
  gap: 8px;
}

.feed-tab {
  background: #fff;
  border: none;
  border-radius: 14px;
  padding: 6px 14px;
  font-size: 13px;
  font-weight: 600;
  color: #8e8e93;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.feed-tab.active {
  background: #1c1c1e;
  color: #fff;
  transform: scale(1.05);
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.message-item {
  display: flex;
  gap: 10px;
  animation: messageSlide 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
}

.message-item:nth-child(1) { animation-delay: 0.1s; }
.message-item:nth-child(2) { animation-delay: 0.2s; }
.message-item:nth-child(3) { animation-delay: 0.3s; }

@keyframes messageSlide {
  from { opacity: 0; transform: translateX(-15px); }
  to { opacity: 1; transform: translateX(0); }
}

.message-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
  position: relative;
}

.avatar-icon {
  font-size: 16px;
}

.message-content {
  flex: 1;
  min-width: 0;
}

.message-bubble {
  background: #fff;
  border-radius: 18px;
  border-bottom-left-radius: 4px;
  padding: 12px 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.message-bubble::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 3px;
  height: 100%;
  background: var(--accent-color, #B8E0D2);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.message-bubble:hover::before {
  opacity: 1;
}

.message-bubble:hover {
  transform: translateX(2px);
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}

.message-text {
  font-size: 14px;
  color: #1c1c1e;
  line-height: 1.5;
  margin-bottom: 6px;
  display: block;
}

.message-meta {
  display: flex;
  align-items: center;
  gap: 8px;
}

.message-mood-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 10px;
}

.message-time {
  font-size: 11px;
  color: #c7c7cc;
}

.message-reply-btn {
  margin-top: 8px;
  padding: 6px 12px;
  background: transparent;
  border: 1px solid #e5e5ea;
  border-radius: 12px;
  font-size: 12px;
  color: #8e8e93;
  display: inline-block;
}

/* 提示 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  background: rgba(0,0,0,0.85);
  color: #fff;
  padding: 14px 28px;
  border-radius: 14px;
  font-size: 15px;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  z-index: 1000;
}

.toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}
