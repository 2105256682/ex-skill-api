<view class="tab-bar">
  <view class="tab-bar-border"></view>

  <!-- 左侧组 -->
  <view class="tab-left-group">
    <!-- 首页 -->
    <view class="tab-item {{selected===0?'active':''}}" data-index="0" bindtap="switchTab">
      <view class="icon-wrap">
        <image class="tab-img" src="data:image/svg+xml;base64," mode="aspectFit" wx:if="{{selected!==0}}"/>
        <image class="tab-img" src="data:image/svg+xml;base64," mode="aspectFit" wx:if="{{selected===0}}"/>
      </view>
      <text class="tab-label">首页</text>
    </view>

    <!-- 广场 -->
    <view class="tab-item {{selected===1?'active':''}}" data-index="1" bindtap="switchTab">
      <view class="icon-wrap">
        <image class="tab-img" src="data:image/svg+xml;base64," mode="aspectFit" wx:if="{{selected!==1}}"/>
        <image class="tab-img" src="data:image/svg+xml;base64," mode="aspectFit" wx:if="{{selected===1}}"/>
      </view>
      <text class="tab-label">广场</text>
    </view>
  </view>

  <!-- 中间 + 按钮 -->
  <view class="add-btn-wrap" bindtap="onAdd">
    <view class="add-btn">
      <view class="plus-h"></view>
      <view class="plus-v"></view>
    </view>
  </view>

  <!-- 右侧组 -->
  <view class="tab-right-group">
    <!-- 消息 -->
    <view class="tab-item {{selected===2?'active':''}}" data-index="2" bindtap="switchTab">
      <view class="icon-wrap" style="position:relative;">
        <image class="tab-img" src="data:image/svg+xml;base64," mode="aspectFit" wx:if="{{selected!==2}}"/>
        <image class="tab-img" src="data:image/svg+xml;base64," mode="aspectFit" wx:if="{{selected===2}}"/>
        <view class="msg-dot"></view>
      </view>
      <text class="tab-label">消息</text>
    </view>

    <!-- 我 -->
    <view class="tab-item {{selected===3?'active':''}}" data-index="3" bindtap="switchTab">
      <view class="icon-wrap">
        <image class="tab-img" src="data:image/svg+xml;base64," mode="aspectFit" wx:if="{{selected!==3}}"/>
        <image class="tab-img" src="data:image/svg+xml;base64," mode="aspectFit" wx:if="{{selected===3}}"/>
      </view>
      <text class="tab-label">我</text>
    </view>
  </view>
</view>
