page {
  width: 100%;
  height: 100%;
  background: #fff;
}

.container {
  width: 100%;
  height: 100%;
}

/* 页面内容固定不滑动 */
.page-content {
  width: 100%;
  height: calc(100vh - 180rpx);
  overflow: hidden;
}

/* 自定义 tabBar 占位 */
.custom-tab-bar-placeholder {
  height: 180rpx;
  padding-bottom: env(safe-area-inset-bottom);
}
